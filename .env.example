# MinerU Rust API 服务配置示例。
# 下面三项只能通过命令行参数配置，不能通过环境变量配置：
# - 监听地址：启动时传入 --host，默认 127.0.0.1。
# - 监听端口：启动时传入 --port，默认 8000。
# - 公网暴露时允许 HTTP-client 后端：启动时传入 --allow-public-http-client。

# 日志级别。
# 如果不设置 RUST_LOG，程序内部默认使用：
# mineru=info,tower_http=info
RUST_LOG=mineru=info,tower_http=info

# API 运行时并发限制。
# 同时处理的解析请求数量；Linux 默认 3，macOS 默认 1。
MINERU_API_MAX_CONCURRENT_REQUESTS=3
# 每个 PDF 解析窗口包含的页数；长文档会按窗口分批渲染和解析。
MINERU_PROCESSING_WINDOW_SIZE=64
# 单个文档内同时发往 VLM 服务的最大请求数。
MINERU_VLM_MAX_CONCURRENCY=100

# 任务输出目录；上传文件、中间结果和解析结果会写到这里。
MINERU_API_OUTPUT_ROOT=./output
# 已完成或失败任务的保留时间，单位秒；0 表示不自动清理。
MINERU_API_TASK_RETENTION_SECONDS=86400
# 后台清理过期任务的扫描间隔，单位秒。
MINERU_API_TASK_CLEANUP_INTERVAL_SECONDS=300

# multipart 请求未传 backend 字段时使用的默认解析后端。
MINERU_API_DEFAULT_BACKEND=vlm-http-client
# 默认 VLM 服务地址；设置后，请求可以不传 multipart server_url 字段。
MINERU_API_DEFAULT_SERVER_URL=

# OpenAI-compatible VLM 服务地址。
# 当请求未传 server_url 且 MINERU_API_DEFAULT_SERVER_URL 为空时，必须设置该项。
MINERU_VL_SERVER=http://127.0.0.1:30000
# VLM 模型名称；为空时，服务会请求 /v1/models，并要求只返回一个模型。
MINERU_VL_MODEL_NAME=
# VLM 服务鉴权 Key；为空时不发送 Authorization 请求头。
MINERU_VL_API_KEY=
# 调用 VLM 服务的 HTTP 超时时间，单位秒。
MINERU_HTTP_TIMEOUT=600
# 从 VLM 返回文本末尾移除的结束标记。
MINERU_VLM_END_TOKEN=<|im_end|>
